<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apply DOH SheetNum"
        Foreground="#000"
        Margin="0"
        Width="560" MinWidth="560"
        SizeToContent="Height"
        ShowInTaskbar="True"
        BorderThickness="0"
        Background="{x:Null}"
        WindowStartupLocation="CenterScreen"
        HorizontalContentAlignment="Center"
        UseLayoutRounding="False"
        FontFamily="RomanD"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        Cursor="Arrow">

    <Window.Resources>
        <!-- House palette, reused from AiRenderForm.xaml -->
        <SolidColorBrush x:Key="TextColor" Color="#FFDAE8FD"/>
        <SolidColorBrush x:Key="AccentColor" Color="#f39c12"/>
        <SolidColorBrush x:Key="PanelColor" Color="#FF464646"/>
        <SolidColorBrush x:Key="PanelColorDeep" Color="#FF2E2E2E"/>
        <SolidColorBrush x:Key="MutedTextColor" Color="#FFCBCBCB"/>
        <SolidColorBrush x:Key="DimTextColor" Color="#FF9A9A9A"/>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <!-- Base (secondary) button: SETUP group -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="{StaticResource TextColor}"/>
            <Setter Property="Foreground" Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <!-- Border stretches to the button; height comes from the
                             overridable MinHeight setter, never hardcoded here,
                             so a button with a custom Height/Width is not cropped. -->
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="3"
                                SnapsToDevicePixels="true">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (accent) button: APPLY group -->
        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12" Margin="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFB84D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCaption" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource DimTextColor}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2,0,0,4"/>
        </Style>
    </Window.Resources>

    <Border BorderThickness="1" BorderBrush="{StaticResource DimTextColor}"
            CornerRadius="15" Margin="20" Name="main_border"
            MouseLeftButtonDown="mouse_down_main_panel">
        <Border.Background>
            <SolidColorBrush Color="#FF464646" Opacity="1"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FFFFE59C" BlurRadius="15" Opacity="0.8"/>
        </Border.Effect>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: title + Close (WindowStyle=None removes native chrome) -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Apply DOH SheetNum"
                           Foreground="#FFFFE59C" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Close" Click="close_Click"
                        ToolTip="Close" Width="72" VerticalAlignment="Center"
                        Background="#33FFFFFF" Foreground="#FFEDEDED"/>
            </Grid>

            <!-- Explanation -->
            <TextBlock Grid.Row="1" Margin="0,0,0,12" FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextColor}"
                       Text="Revit keeps ONE unique SheetNumber per sheet. This tool stores the Internal and DOH numbering in two permanent parameters and copies the chosen scheme into the live slot. Initialize seeds both stores from the current live number, filling only empty cells (existing values are kept). Apply then copies a stored scheme into the live SheetNumber."/>

            <!-- Mode banner: the loudest element (what Apply will act on) -->
            <Border Grid.Row="2" Margin="0,0,0,10" CornerRadius="8" Padding="12,7"
                    Background="{StaticResource AccentColor}">
                <TextBlock x:Name="ModeText" Text="Mode:"
                           Foreground="White" FontWeight="Bold" FontSize="13"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Health line (compact stats) -->
            <Border Grid.Row="3" Margin="0,0,0,8" CornerRadius="8" Padding="10,7"
                    Background="{StaticResource PanelColorDeep}">
                <TextBlock x:Name="HealthText" FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap" Foreground="{StaticResource TextColor}"/>
            </Border>

            <!-- Report / blocking-reason panel (scrolls) + Copy log -->
            <StackPanel Grid.Row="4" Margin="0,0,0,14">
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="REPORT"
                               Style="{StaticResource SectionCaption}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="CopyLogButton" Content="Copy log"
                            Click="copy_log_click"
                            ToolTip="Copy the mode, health, and report text to the clipboard"
                            MinHeight="22" FontSize="10" Padding="8,0,8,0"
                            Background="#33FFFFFF" Foreground="#FFEDEDED"
                            HorizontalAlignment="Right"/>
                </Grid>
                <Border CornerRadius="8" Padding="10,8"
                        Background="{StaticResource PanelColorDeep}" MaxHeight="150">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ReportText" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Foreground="{StaticResource MutedTextColor}"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- SETUP group -->
            <StackPanel Grid.Row="5" Margin="0,0,0,10">
                <TextBlock Text="SETUP" Style="{StaticResource SectionCaption}"/>
                <Button x:Name="InitializeButton"
                        Content="Initialize Internal &amp; DOH from live"
                        Click="initialize_click"/>
            </StackPanel>

            <!-- APPLY group (primary) -->
            <StackPanel Grid.Row="6">
                <TextBlock Text="APPLY" Style="{StaticResource SectionCaption}"/>
                <Button x:Name="ApplyDohButton" Style="{StaticResource PrimaryButton}"
                        Content="Apply DOH Numbering" Click="apply_doh_click"/>
                <Button x:Name="ApplyInternalButton" Style="{StaticResource PrimaryButton}"
                        Content="Apply Internal Numbering" Click="apply_internal_click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
